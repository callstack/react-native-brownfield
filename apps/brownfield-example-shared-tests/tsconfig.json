{
  "compilerOptions": {
    "baseUrl": ".",
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": ["jest"],
    "paths": {
      "@callstack/react-native-brownfield": [
        "../../packages/react-native-brownfield/src/index.ts"
      ],
      "@callstack/brownfield-navigation": [
        "../../packages/brownfield-navigation/src/index.ts"
      ],
      "@callstack/brownie": ["../../packages/brownie/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/global.d.ts"]
}
