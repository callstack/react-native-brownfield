  "brownie": {
    "kotlin": "./android/brownfieldlib/src/main/java/com/callstack/rnbrownfield/demo/expoapp55/Generated/",
    "kotlinPackageName": "com.callstack.rnbrownfield.demo.expoapp55"
  }
