+package expo.modules.updates
+
+import com.facebook.react.ReactHost
+
+/**
+ * Supplies the [ReactHost] for brownfield / embedded React Native setups where
+ * [android.app.Application] is not the standard [com.facebook.react.ReactApplication]
+ * with a framework-provided `reactHost`.
+ *
+ * Register via [UpdatesController.setReactHostProvider] on the main thread after the host exists.
+ */
+fun interface ReactHostProvider {
+  fun getReactHost(): ReactHost?
+
+  fun isReactHostReady(): Boolean = getReactHost() != null
+}
