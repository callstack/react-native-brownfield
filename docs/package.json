{
  "name": "react-native-brownfield-docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "scripts": {
    "copy:schema": "node ./scripts/copy-schema.mjs",
    "dev": "yarn run copy:schema && rspress dev",
    "build": "yarn run copy:schema && rspress build",
    "build:docs": "yarn run build",
    "preview": "rspress preview"
  },
  "dependencies": {
    "@callstack/rspress-preset": "^0.6.0",
    "@rspress/core": "^2.0.9"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
